; Initial sandbox profile for opencode CLI
; Goal: allow read/write in /Users/amin/dev and /Users/amin/.config/opencode

(version 1)
(debug deny)

; Keep non-file behavior unchanged for an initial setup.
(allow default)

; Important: on current macOS sandbox matching behaves as last-match-wins.
; Put broad denies first, then carve out explicit allows.
(deny file-write*)
(deny file-read* (subpath "/Users/amin"))

; Restrict subprocess execution to trusted locations/binaries.
; Keep (allow default), but make process-exec default-deny.
(deny process-exec)

; Allow the primary opencode binary.
(allow process-exec (literal "/Users/amin/.opencode/bin/opencode"))

; Allow execution from standard system and toolchain locations.
(allow process-exec (subpath "/bin"))
(allow process-exec (subpath "/usr/bin"))
(allow process-exec (subpath "/usr/sbin"))
(allow process-exec (subpath "/Library/Developer/CommandLineTools/usr/bin"))
(allow process-exec (subpath "/Library/Developer/CommandLineTools/Library/Frameworks/Python3.framework"))
(allow process-exec (subpath "/opt/homebrew/bin"))
(allow process-exec (subpath "/opt/homebrew/Cellar"))
(allow process-exec (subpath "/opt/homebrew/Cellar/mise"))
(allow process-exec (subpath "/usr/local/bin"))
(allow process-exec (subpath "/Applications/Docker.app/Contents/Resources/bin"))
(allow process-exec (subpath "/Users/amin/.local/share/mise/installs"))
(allow process-exec (subpath "/Users/amin/.local/share/mise/shims"))
(allow process-exec (subpath "/Users/amin/.local/share/uv/python"))
(allow process-exec (subpath "/Users/amin/.cargo/bin"))
(allow process-exec (subpath "/Users/amin/.config/opencode/skills"))

; Allow running project-local tools (venvs, node_modules/.bin, scripts).
(allow process-exec (subpath "/Users/amin/dev"))

; Re-block high-risk launcher helpers.
(deny process-exec (literal "/bin/launchctl"))
(deny process-exec (literal "/usr/bin/open"))
(deny process-exec (literal "/usr/bin/osascript"))


; Permit file access in the allowed writable trees.
(allow file-read* (subpath "/Users/amin/dev"))
(allow file-write* (subpath "/Users/amin/dev"))
(allow file-read* (subpath "/private/tmp"))
(allow file-write* (subpath "/private/tmp"))
(allow file-read* (subpath "/private/var/folders"))
(allow file-write* (subpath "/private/var/folders"))
(allow file-read* (subpath "/Users/amin/.config/opencode"))
(allow file-write* (subpath "/Users/amin/.config/opencode"))
(allow file-read* (subpath "/Users/amin/.local/share/opencode"))
(allow file-write* (subpath "/Users/amin/.local/share/opencode"))
(allow file-read* (subpath "/Users/amin/.local/state/opencode"))
(allow file-write* (subpath "/Users/amin/.local/state/opencode"))
(allow file-read* (subpath "/Users/amin/.local/state/mise"))
(allow file-write* (subpath "/Users/amin/.local/state/mise"))
(allow file-read* (subpath "/Users/amin/.cache/opencode"))
(allow file-write* (subpath "/Users/amin/.cache/opencode"))
(allow file-read* (subpath "/Users/amin/.cache/uv"))
(allow file-write* (subpath "/Users/amin/.cache/uv"))
(allow file-read* (subpath "/Users/amin/.local/share/uv"))
(allow file-write* (subpath "/Users/amin/.local/share/uv"))
(allow file-read* (subpath "/Users/amin/.local/share/mise"))
(allow file-read* (subpath "/opt/homebrew/Cellar/mise"))
(allow file-read* (subpath "/Users/amin/Library/Caches/mise"))
(allow file-write* (subpath "/Users/amin/Library/Caches/mise"))
(allow file-read* (subpath "/Users/amin/Library/Application Support/mise"))
(allow file-read* (subpath "/Users/amin/.config/mise"))
(allow file-read* (subpath "/Users/amin/.config/gh"))
(allow file-read* (subpath "/Users/amin/.config/git"))
(allow file-read* (subpath "/Users/amin/.docker"))
(allow file-read* (literal "/Users/amin/.gitconfig"))
(allow file-read* (literal "/Users/amin/.tool-versions"))
(allow file-read* (literal "/Users/amin/.mise.toml"))
(allow file-read* (literal "/Users/amin/.bash_profile"))
(allow file-read* (subpath "/Users/amin/Library/Application\ Support/Google/Chrome Canary/"))

; Permit opencode runtime and system read-only dependencies.
(allow file-read* (subpath "/Users/amin/.opencode"))

; Permit standard null-device writes.
(allow file-write* (literal "/dev/null"))

; Allow minimal directory metadata lookup needed for path traversal.
(allow file-read-metadata (literal "/"))
(allow file-read-metadata (literal "/Users"))
(allow file-read-metadata (literal "/Users/amin"))
(allow file-read-metadata (literal "/Users/amin/.config"))
(allow file-read-metadata (literal "/Users/amin/.cache"))
(allow file-read-metadata (literal "/Users/amin/.local"))
(allow file-read-metadata (literal "/Users/amin/.local/share"))
(allow file-read-metadata (literal "/Users/amin/.local/share/uv"))
(allow file-read-metadata (literal "/Users/amin/.local/state"))
(allow file-read-metadata (literal "/Users/amin/.local/state/mise"))
(allow file-read-metadata (literal "/Users/amin/Library"))
(allow file-read-metadata (literal "/Users/amin/Library/Caches"))
(allow file-read-metadata (literal "/Users/amin/Library/Caches/mise"))
(allow file-read-metadata (literal "/Users/amin/Library/Application Support"))
(allow file-read-metadata (literal "/Users/amin/Library/Application Support/mise"))
(allow file-read-metadata (literal "/Users/amin/.config/opencode"))
(allow file-read-metadata (literal "/Users/amin/.config/opencode/skills"))
